# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ==============================================================================
# AUTHENTICATION & SECURITY
# ==============================================================================

JWT_SECRET="your-secret-key-here"
JWT_REFRESH_SECRET="your-refresh-secret-here"
SESSION_TIMEOUT="14400000"

# ==============================================================================
# FILE UPLOAD & MEDIA
# ==============================================================================

UPLOAD_DIR="./public/uploads"
MAX_FILE_SIZE="10485760"
MEDIA_URL="http://localhost:3000/uploads"

# ==============================================================================
# CLOUD STORAGE (OPTIONAL)
# ==============================================================================

# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_S3_BUCKET=""
# AWS_REGION="us-east-1"

# CLOUDINARY_URL=""

# ==============================================================================
# DEVELOPMENT
# ==============================================================================

NODE_ENV="development"
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Unsplash API (optional — enables stock photo search in Volt designer)
UNSPLASH_ACCESS_KEY=

# ==============================================================================
# GOOGLE SEARCH CONSOLE (OPTIONAL)
# ==============================================================================
# OAuth 2.0 app from Google Cloud Console (Search Console API + URL Inspection API)
# Redirect URI must be registered as: https://yourdomain.com/api/seo/gsc/callback

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/seo/gsc/callback"

# AES-256-GCM key for encrypting stored OAuth tokens (64 hex chars)
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex').then?console.log:console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or simply: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GSC_ENCRYPTION_KEY=""
