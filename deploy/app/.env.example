# =============================================================================
# White-Label CMS — Production Environment Variables
# Copy this to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# ── Site identity (REQUIRED — must be unique per site on this Traefik) ────────
# Slug used for Traefik router/service names and container names.
# Use lowercase letters, digits, and hyphens only. e.g. "sonic-cms", "acme-cms"
APP_NAME=sonic-cms

# Public domain for this CMS instance
DOMAIN=yourcompany.co.za

# ── Database ──────────────────────────────────────────────────────────────────
# Host is "db" — the PostgreSQL service name in docker-compose.yml
DATABASE_URL="postgresql://sonic:CHANGE_ME_STRONG_PASSWORD@db:5432/sonic_cms"

# Must match DATABASE_URL credentials above
POSTGRES_USER=sonic
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=sonic_cms

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64  (or: python -c "import secrets,base64;print(base64.b64encode(secrets.token_bytes(64)).decode())")
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_DIFFERENT_VALUE
SESSION_TIMEOUT=14400000

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_API_URL=https://sonicweb.dedicated.co.za
SKIP_MIGRATIONS=false

# ── Staging domain (optional) ─────────────────────────────────────────────────
# Temporary domain for access before DNS cutover. Clear after going live.
STAGING_DOMAIN=sonicweb.dedicated.co.za

# ── Media / Uploads ───────────────────────────────────────────────────────────
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=10485760
MEDIA_URL=https://sonicweb.dedicated.co.za/uploads
